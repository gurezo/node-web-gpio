{
  "name": "node-web-gpio",
  "version": "1.0.13",
  "description": "GPIO access with Node.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/chirimen-oh/node-web-gpio.git"
  },
  "author": "Kohei Watanabe <kou029w@gmail.com>",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^17.0.6",
    "@typescript-eslint/eslint-plugin": "^5.8.1",
    "@typescript-eslint/parser": "^5.8.1",
    "eslint": "^8.6.0",
    "husky": "^7.0.4",
    "lint-staged": "^12.1.5",
    "prettier": "^2.5.1",
    "events": "^3.3.0",
    "fs": "^0.0.1-security",
    "path": "^0.12.7",
    "typedoc": "^0.22.10",
    "typescript": "~4.5.5"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint index.ts",
    "prepare": "husky install && rm -rf dist && npm run build",
    "precommit": "lint-staged",
    "docs": "npm run remove:docs && npm run typedoc -- --options typedoc.json --exclude '**/*.spec.ts' ./ README.md",
    "typedoc": "typedoc",
    "remove:docs": "rm -rf docs"
  },
  "keywords": [
    "gpio",
    "hardware",
    "iot",
    "linux",
    "pi",
    "raspberry",
    "raspberry pi",
    "raspi",
    "robot",
    "robotics",
    "robots",
    "rpi"
  ]
}
